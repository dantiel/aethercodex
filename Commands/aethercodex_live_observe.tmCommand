<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>beforeRunningCommand</key>
  <string>nop</string>
  <key>command</key>
  <string><![CDATA[#!/usr/bin/env bash
# IMMEDIATELY fork to background to prevent UI blocking

set -e
#BUNDLE_SUPPORT="$TM_BUNDLE_SUPPORT"
#PROJECT_ROOT="$TM_PROJECT_DIRECTORY"
#export BUNDLE_GEMFILE="$BUNDLE_SUPPORT/Gemfile"
#export GEM_HOME="$BUNDLE_SUPPORT/.vendor_bundle"
#export GEM_PATH="$GEM_HOME"
#
#cd "$BUNDLE_SUPPORT"

# Read document content from stdin
export CONTENT=$(cat)

# Get selection information if available
export TM_SELECTED_TEXT="${TM_SELECTED_TEXT:-}"
export TM_SELECTION_START="${TM_SELECTION_START:-}"
export TM_SELECTION_END="${TM_SELECTION_END:-}"
export TM_CURRENT_LINE="${TM_CURRENT_LINE:-}"

# Simple time-based debouncing using file timestamps
STATE_FILE="/tmp/aethercodex_buffer"
CURRENT_TIME=$(date +%s)

# Check if we should skip (processed within last 200ms)
if [[ -f "$STATE_FILE" ]]; then
  LAST_TIME=$(stat -f %m "$STATE_FILE" 2>/dev/null || echo "0")
  if (( CURRENT_TIME - LAST_TIME < 1 )); then  # 1 second debounce
    exit 0
    #echo "ok22"
  fi
fi

# Update the buffer state (touch file)
touch "$STATE_FILE"

export PORT="4567"
(
# Push to server with minimal overhead (use system ruby)
nohup /usr/bin/ruby -rnet/http -rjson -e '
# Arguments passed from Bash
filepath = ENV["TM_FILEPATH"] || "unknown"
cursor_line = ENV["TM_LINE_NUMBER"] || "1"
scope = ENV["TM_SCOPE"] || "unknown"
content = ENV["CONTENT"] || ""
error_log = "/tmp/aethercodex_errors.log"

begin
  # Parse selection range if available
  selection_range = nil
  if ENV["TM_SELECTION_START"] && ENV["TM_SELECTION_END"]
    selection_range = "#{ENV["TM_SELECTION_START"]}:#{ENV["TM_SELECTION_END"]}"
  end
  
  payload = {
    path: filepath,
    cursor: cursor_line.to_i,
    content: content, # Raw content, JSON encoding happens below
    timestamp: Time.now.to_f, # Higher precision timestamp
    event: ENV["TM_REFRESH"] || "change", # Get env var if set
    type: "hermetic_document_update",
    scope: scope,
    language: scope.split(".").last || "unknown",
    selected_text: ENV["TM_SELECTED_TEXT"] || "",
    selection_range: selection_range,
    current_line: ENV["TM_CURRENT_LINE"] || ""
  }.to_json # Generate JSON *here*
  
  uri = URI("http://0.0.0.0:4567/hermetic_live_update")
  http = Net::HTTP.new(uri.host, uri.port)
  http.open_timeout = 0.5
  http.read_timeout = 1
  request = Net::HTTP::Post.new(uri.path, {"Content-Type" => "application/json"})
  request.body = payload
  response = http.request(request)
rescue => e 
  # ignore all errors
  File.write(error_log, "[#{Time.now}] Error: #{e.class} - #{e.message}\n#{e.backtrace.join("\n")}\n---\n", mode: "a")
end
' &
) & disown # This & forks the entire block to background

exit 0
# TextMate command exits immediately
]]></string>
  
	<key>input</key>
	<string>document</string>
	<key>inputFormat</key>
	<string>text</string>
	<key>keyEquivalent</key>
	<string></string>
	<key>name</key>
	<string>AetherCodex Live Observe</string>
	<key>outputCaret</key>
	<string>afterOutput</string>
	<key>outputLocation</key>
	<string>discard</string>
	<key>outputFormat</key>
	<string>text</string>
	<key>scope</key>
	<string>attr.aethercodex</string>
	<key>uuid</key>
	<string>C86306D6-AD8C-42A4-8D8E-8D840BC00E74</string>
	<key>version</key>
	<string>5</string>
  
  <key>autoRefresh</key>
  <array>
    <string>DocumentSaved</string>
    <string>DocumentChanged</string>
    <string>DocumentClosed</string>
  </array>
  
  <key>semanticClass</key>
  <string>callback.document.did-open</string>
  
</dict>
</plist>