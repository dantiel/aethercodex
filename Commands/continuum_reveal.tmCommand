<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>beforeRunningCommand</key>
	<string>nop</string>
	<key>command</key>
	<string><![CDATA[#!/usr/bin/env bash
set -e

SUPPORT="${TM_BUNDLE_SUPPORT:=$TM_DIRECTORY/Support}"
BUNDLE_SUPPORT="$TM_BUNDLE_SUPPORT"
BUNDLE_SUPPORT_UI=$(echo "file://$BUNDLE_SUPPORT/pythia" | perl -pe 's/\//\\\//g')
PROJECT_ROOT=$TM_PROJECT_DIRECTORY
export BUNDLE_GEMFILE="$BUNDLE_SUPPORT/Gemfile"
export GEM_HOME="$BUNDLE_SUPPORT/.vendor_bundle"
export GEM_PATH="$GEM_HOME"

# Get the entire document content from stdin
DOCUMENT_CONTENT=$(cat)

# Optional RVM
if [[ -s "$HOME/.rvm/scripts/rvm" ]]; then
  source "$HOME/.rvm/scripts/rvm"
  rvm use 3.1@aethercodex --create >/dev/null 2>&1 || true
fi

# Determine mode: cursor or selection
if [[ -n "$TM_SELECTED_TEXT" ]]; then
  MODE="selection"
  export SELECTION_MODE="true"
  export SELECTED_TEXT="$TM_SELECTED_TEXT"
  export SELECTION_RANGE="$TM_SELECTION"
else
  MODE="cursor"
  export SELECTION_MODE="false"
fi

# Calculate context based on mode
export BEFORE_CONTEXT=$(cd "$SUPPORT" && bundle exec ruby -e "
  document_content = ARGF.read

  # Split into lines
  lines = document_content.split(\"\n\")
  
  if ENV['SELECTION_MODE'] == 'true'
    # Selection mode - parse selection range
    selection_range = ENV['SELECTION_RANGE']
    selected_text = ENV['SELECTED_TEXT']
    
    # Parse selection range format: 36:20-37:4 or 36-37 or 36:20-37 or 36-37:4 or 36:20
    if selection_range =~ /^(\d+)(?::(\d+))?(-(\d+)(?::(\d+))?)?$/
      start_line = \$1.to_i - 1  # Convert to 0-based
      start_col = \$2 ? \$2.to_i - 1 : 0
      end_line = \$4 ? \$4.to_i - 1 : start_line
      end_col = \$5 ? \$5.to_i : -1
      
      # Get context before selection
      max_chars = 2000
      collected_lines = []
      current_chars = 0
      
      # Add lines before selection
      before_start_line = [0, start_line - 20].max
      before_lines = lines[before_start_line...start_line] || []
      
      before_lines.reverse_each do |line|
        line_length = line.length + 1
        if current_chars + line_length <= max_chars
          collected_lines.unshift(line)
          current_chars += line_length
        else
          break
        end
      end
      
      # Add start line up to selection
      if lines[start_line]
        start_line_before = lines[start_line][0...start_col]
        if start_line_before && current_chars + start_line_before.length <= max_chars
          collected_lines << start_line_before
        end
      end
      
      before_context = collected_lines.join(\"\n\")
      puts before_context
    else
      # Fallback to cursor mode if selection parsing fails
      puts ''
    end
  else
    # Cursor mode - original logic
    line_num = (ENV['TM_LINE_NUMBER'] || '1').to_i - 1
    column_num = (ENV['TM_COLUMN_NUMBER'] || '1').to_i - 1
    
    max_chars = 2000
    before_start_line = [0, line_num - 20].max
    before_lines = lines[before_start_line...line_num] || []
    
    collected_lines = []
    current_chars = 0
    
    before_lines.reverse_each do |line|
      line_length = line.length + 1
      if current_chars + line_length <= max_chars
        collected_lines.unshift(line)
        current_chars += line_length
      else
        break
      end
    end
    
    current_line_before = lines[line_num][0...column_num] if lines[line_num]
    
    if current_line_before && current_chars + current_line_before.length <= max_chars
      collected_lines << current_line_before
    end
    
    before_context = collected_lines.join(\"\n\")
    puts before_context
  end
" <<< "$DOCUMENT_CONTENT")

# Calculate after context
export AFTER_CONTEXT=$(cd "$SUPPORT" && bundle exec ruby -e "
  document_content = ARGF.read
  
  # Split into lines
  lines = document_content.split(\"\n\")
  
  if ENV['SELECTION_MODE'] == 'true'
    # Selection mode
    selection_range = ENV['SELECTION_RANGE']
    selected_text = ENV['SELECTED_TEXT']
    
    if selection_range =~ /^(\d+)(?::(\d+))?-(\d+)(?::(\d+))?$/
      start_line = \$1.to_i - 1
      start_col = \$2 ? \$2.to_i - 1 : 0
      end_line = \$3 ? \$3.to_i - 1 : start_line
      end_col = \$4 ? \$4.to_i : -1
      
      # Get context after selection
      max_chars = 2000
      collected_lines = []
      current_chars = 0
      
      # Add end line after selection
      if lines[end_line] && end_col >= 0
        end_line_after = lines[end_line][end_col..-1]
        if end_line_after && current_chars + end_line_after.length <= max_chars
          collected_lines << end_line_after
          current_chars += end_line_after.length
        end
      end
      
      # Add lines after selection
      after_start_line = end_line + 1
      after_end_line = [lines.length, after_start_line + 20].min
      after_lines = lines[after_start_line...after_end_line] || []
      
      after_lines.each do |line|
        line_length = line.length + 1
        if current_chars + line_length <= max_chars
          collected_lines << line
          current_chars += line_length
        else
          break
        end
      end
      
      after_context = collected_lines.join(\"\n\")
      puts after_context
    else
      puts ''
    end
  else
    # Cursor mode - original logic
    line_num = (ENV['TM_LINE_NUMBER'] || '1').to_i - 1
    column_num = (ENV['TM_COLUMN_NUMBER'] || '1').to_i - 1
    
    max_chars = 2000
    collected_lines = []
    current_chars = 0
    
    current_line_after = lines[line_num][column_num..-1] if lines[line_num]
    
    if current_line_after && current_chars + current_line_after.length <= max_chars
      collected_lines << current_line_after
      current_chars += current_line_after.length
    end
    
    after_start_line = line_num + 1
    after_end_line = [lines.length, after_start_line + 20].min
    after_lines = lines[after_start_line...after_end_line] || []
    
    after_lines.each do |line|
      line_length = line.length + 1
      if current_chars + line_length <= max_chars
        collected_lines << line
        current_chars += line_length
      else
        break
      end
    end
    
    after_context = collected_lines.join(\"\n\")
    puts after_context
  end
" <<< "$DOCUMENT_CONTENT")

# Call continuum weaver for revelation
RESULT=$(cd "$SUPPORT" && bundle exec ruby -e "
  require_relative 'config'
  require_relative 'oracle/continuum_weaver'
  
  if ENV['SELECTION_MODE'] == 'true'
    result = ContinuumWeaver.refactor(
      before_context: ENV['BEFORE_CONTEXT'],
      after_context: ENV['AFTER_CONTEXT'],
      selected_text: ENV['SELECTED_TEXT'],
      selection_range: ENV['SELECTION_RANGE'],
      file_path: ENV['TM_FILEPATH']
    )
  else
    result = ContinuumWeaver.complete(
      before_context: ENV['BEFORE_CONTEXT'],
      after_context: ENV['AFTER_CONTEXT'],
      file_path: ENV['TM_FILEPATH'],
      cursor_line: (ENV['TM_LINE_NUMBER'] || '1').to_i,
      cursor_column: (ENV['TM_COLUMN_NUMBER'] || '1').to_i
    )
  end
  
  puts result
")

echo "Continuum Revelation ($MODE mode):"
echo "$RESULT"
]]></string>
	<key>input</key>
	<string>document</string>
	<key>inputFormat</key>
	<string>text</string>
	<key>keyEquivalent</key>
	<string>^~f</string>
	<key>name</key>
	<string>Continuum Reveal</string>
  
  <!--
	<key>semanticClass</key>
	<string>callback.document.did-open</string>
  //-->
	<key>outputCaret</key>
	<string>afterOutput</string>
	<key>outputLocation</key>
	<string>toolTip</string>
	<key>outputFormat</key>
	<string>text</string>
	<key>scope</key>
	<string>source</string>
	<key>uuid</key>
	<string>B86306D6-AD8C-42A4-8D8E-8D840BC00E72</string>
	<key>version</key>
	<string>2</string>
</dict>
</plist>