<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>beforeRunningCommand</key>
	<string>nop</string>
	<key>command</key>
	<string><![CDATA[#!/usr/bin/env bash
set -e
SUPPORT="${TM_BUNDLE_SUPPORT:=$TM_DIRECTORY/Support}"

# Get the entire document content from stdin
DOCUMENT_CONTENT=$(cat)

# Determine mode: cursor or selection
if [[ -n "$TM_SELECTED_TEXT" ]]; then
  MODE="selection"
  export SELECTION_MODE="true"
  export SELECTED_TEXT="$TM_SELECTED_TEXT"
  export SELECTION_RANGE="$TM_SELECTION"
else
  MODE="cursor"
  export SELECTION_MODE="false"
fi

# Calculate context based on mode
export BEFORE_CONTEXT=$(cd "$SUPPORT" && bundle exec ruby -e "
  require_relative 'instrumentarium/context_extractor'
  
  document_content = ARGF.read
  
  context = if ENV['SELECTION_MODE'] == 'true'
    # Selection mode
    ContextExtractor.extract_context_around_selection \
      document_content,
      ENV['SELECTION_RANGE'],
      ENV['SELECTED_TEXT']
  else
    # Cursor mode
    line_num = (ENV['TM_LINE_NUMBER'] || '1').to_i
    column_num = (ENV['TM_COLUMN_NUMBER'] || '1').to_i
    
    ContextExtractor.extract_context_around_cursor \
      document_content,
      line_num,
      column_num
  end
  puts context[:before]
" <<< "$DOCUMENT_CONTENT")


# Calculate after context
export AFTER_CONTEXT=$(cd "$SUPPORT" && bundle exec ruby -e "
  require_relative 'instrumentarium/context_extractor'
  
  document_content = ARGF.read
  
  context = if ENV['SELECTION_MODE'] == 'true'
    # Selection mode
    ContextExtractor.extract_context_around_selection \
      document_content,
      ENV['SELECTION_RANGE'],
      ENV['SELECTED_TEXT']
  else
    # Cursor mode
    line_num = (ENV['TM_LINE_NUMBER'] || '1').to_i
    column_num = (ENV['TM_COLUMN_NUMBER'] || '1').to_i
    
    ContextExtractor.extract_context_around_cursor \
      document_content,
      line_num,
      column_num
  end
  puts context[:after]
" <<< "$DOCUMENT_CONTENT")


# Call continuum weaver for inscription
RESULT=$(cd "$SUPPORT" && bundle exec ruby -e "
  require_relative 'config'
  require_relative 'oracle/continuum_weaver'
  
  result = if ENV['SELECTION_MODE'] == 'true'
    ContinuumWeaver.refactor \
      before_context: ENV['BEFORE_CONTEXT'],
      after_context: ENV['AFTER_CONTEXT'],
      selected_text: ENV['SELECTED_TEXT'],
      selection_range: ENV['SELECTION_RANGE'],
      scope: ENV['TM_SCOPE'],
      file_path: ENV['TM_FILEPATH']
  else
    ContinuumWeaver.complete \
      before_context: ENV['BEFORE_CONTEXT'],
      after_context: ENV['AFTER_CONTEXT'],
      scope: ENV['TM_SCOPE'],
      file_path: ENV['TM_FILEPATH'],
      cursor_line: (ENV['TM_LINE_NUMBER'] || '1').to_i,
      cursor_column: (ENV['TM_COLUMN_NUMBER'] || '1').to_i
  end
  
  puts result
")

# Inscribe the result
echo -n "$RESULT"
]]></string>
	<key>input</key>
	<string>document</string>
	<key>inputFormat</key>
	<string>text</string>
	<key>keyEquivalent</key>
	<string>^~g</string>
	<key>name</key>
	<string>Continuum Inscribe</string>
	<key>outputCaret</key>
	<string>afterOutput</string>
	<key>outputLocation</key>
	<string>replaceSelection</string>
	<key>outputFormat</key>
	<string>text</string>
	<key>scope</key>
	<string>source</string>
	<key>uuid</key>
	<string>7D6540A1-E0DC-4AA1-A16F-EE57E7AF5380</string>
	<key>version</key>
	<string>2</string>
</dict>
</plist>