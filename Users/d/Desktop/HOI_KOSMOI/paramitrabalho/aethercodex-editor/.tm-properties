# TextMate Properties for AetherCodex Editor
# These configure TextMate behavior when editing this project

# Project root
projectDirectory = "$CWD"

# File associations
[ *.swift ]
fileType = "sourcecode.swift"

[ *.rb ]
fileType = "sourcecode.ruby"

[ *.coffee ]
fileType = "sourcecode.coffeescript"

[ *.md ]
fileType = "net.daringfireball.markdown"

# Build commands
[ build ]
command = "cd \"$CWD\" && xcodebuild -project AetherCodex.xcodeproj -scheme AetherCodex build"

[ run ]
command = "cd \"$CWD\" && open build/Release/AetherCodex.app"

# Exclude patterns
[ exclude ]
*.xcodeproj/*
*.xcworkspace/*
build/*
DerivedData/*
.git/*
.tm-ai/*

# Editor settings
[ editor ]
softTabs = true
tabSize = 4
lineEnding = "\n"
encoding = "UTF-8"

# Show in file browser
[ fileBrowser ]
showHiddenFiles = false
