#!/usr/bin/env bash
# Wrapper: strips --map when --stdio/-s is present
# CoffeeScript 2.x rejects --stdio + --map together
set -e

REAL_COFFEE="/Users/d/.nvm/versions/node/v9.3.0/bin/coffee"

has_stdio=false
for a in "$@"; do
  [[ "$a" == "-s" || "$a" == "--stdio" ]] && has_stdio=true && break
done

args=()
for a in "$@"; do
  [[ "$a" == "--map" && "$has_stdio" == true ]] && continue
  args+=("$a")
done

exec "$REAL_COFFEE" "${args[@]}"
